# ==========================================================================
#  Auto Service - Variáveis de Ambiente
# ==========================================================================
# Copie/ajuste conforme necessário. Este arquivo é lido automaticamente
# pelo docker-compose.

# --- Gateway / Domínio --------------------------------------------------
# Porta pública do gateway (Nginx). O domínio deve apontar para esta porta.
GATEWAY_PORT=80
# Porta alternativa local (acesso por http://localhost:8080)
HUB_PORT=8080

# --- LOGIN ÚNICO (protege Hub, PDF, Removedor de Fundo e OCR) ------------
# Único usuário/senha do sistema. ALTERE a senha e a chave secreta!
AUTH_USER=admin
AUTH_PASSWORD=altcorp@2026
# Chave para assinar o cookie de sessão — troque por um valor aleatório longo.
AUTH_SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria-9f3a1c
# Duração da sessão (horas)
AUTH_SESSION_HOURS=12
# Marque o cookie como Secure (use "true" somente quando servir por HTTPS)
AUTH_COOKIE_SECURE=false

# --- oCIS (Gerenciador de Arquivos — login próprio, porta 9200) ---------
# URL de acesso ao oCIS (HTTPS obrigatório: o IDP embutido exige issuer https).
# Para expor no domínio, troque para:
#   OCIS_URL=https://altservice.altcorphub.com:9200
# (e resete os volumes do oCIS: docker volume rm auto-service_ocis-config auto-service_ocis-data)
OCIS_URL=https://localhost:9200
OCIS_PORT=9200
# Senha do usuário administrador (login: admin)
OCIS_ADMIN_PASSWORD=altcorp@2026
# Cria usuários de demonstração (alan / mary / etc. senha: demo)
OCIS_CREATE_DEMO_USERS=true
# Aceita certificados autoassinados (ambiente local)
OCIS_INSECURE=true
OCIS_LOG_LEVEL=error

# --- PaddleOCR ----------------------------------------------------------
# Idioma padrão do OCR: pt, en, ch, korean, japan, etc.
PADDLE_OCR_LANG=pt
